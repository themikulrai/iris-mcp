# === Required ===
SLURM_MCP_USERNAME=your_username

# === Connection (defaults work for Stanford IRIS) ===
# SLURM_MCP_LOGIN_NODE=sc.stanford.edu
# SLURM_MCP_SSH_TIMEOUT=10
# SLURM_MCP_COMMAND_TIMEOUT=60

# === Slurm Defaults ===
# SLURM_MCP_DEFAULT_ACCOUNT=iris
# SLURM_MCP_DEFAULT_PARTITION=iris
# SLURM_MCP_DEFAULT_TIME=24:00:00
# SLURM_MCP_DEFAULT_MEM=32G
# SLURM_MCP_DEFAULT_GPUS=1
# SLURM_MCP_DEFAULT_CPUS=4
# SLURM_MCP_OUTPUT_DIR=slurm

# === Directories (auto-derived from USERNAME if not set) ===
# SLURM_MCP_WORKING_DIR=/iris/u/your_username
# SLURM_MCP_CONDA_DIR=/iris/u/your_username/data/miniforge3
# SLURM_MCP_HOME_DIR=/sailhome/your_username

# === Cluster-specific ===
# SLURM_MCP_GPU_COMMAND=sgpu -p iris
# SLURM_MCP_PARTITIONS=iris,iris-hi,iris-interactive,iris-hi-interactive
